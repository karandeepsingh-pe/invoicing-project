# Postgres connection used by Prisma at runtime.
# Local dev: the pre-created Docker/local role + database (no pooler).
# Production (Vercel + Neon): the Neon POOLED connection string (host contains
#   "-pooler") so serverless functions reuse connections instead of opening a
#   fresh one per request. Append ?sslmode=require if Neon omits it.
DATABASE_URL="postgresql://invoicing:invoicing@localhost:5432/invoicing?schema=public"

# Direct (unpooled) connection used by `prisma migrate` / DDL (needs session
# advisory locks the pooler lacks). Local: same as DATABASE_URL. Production
# (Neon): the UNPOOLED connection string (host has no "-pooler").
DIRECT_URL="postgresql://invoicing:invoicing@localhost:5432/invoicing?schema=public"

# Admin gate (current). The app has NO in-app login yet, so every request is
# treated as this admin user. MUST be set in production for the app to work.
# (When Microsoft Entra ID auth lands — see docs/auth-rbac-plan.md — this goes away.)
DEV_ADMIN_EMAIL="admin@ovationwps.com"

# Public app name (optional; has a default).
NEXT_PUBLIC_APP_NAME="Ovation Invoicing"

# Soft-delete affordances (timesheet cell/row/month, dispatch visit).
# "true" enables them. Recommended "true" while testing so delete/restore works.
SOFT_DELETE_ENABLED="false"

# Shared-password gate (src/middleware.ts). Because the app has no in-app login
# yet, set BOTH of these in production so only people with the shared username +
# password can reach the open-admin instance. Leave them UNSET locally so dev is
# open. Removed once Entra ID auth lands.
# BASIC_AUTH_USER="testers"
# BASIC_AUTH_PASSWORD="<a long random shared password>"

# --- NextAuth / Microsoft Entra ID (NOT used yet; reserved for the auth pass) ---
# Leave these UNSET until you wire Entra ID (docs/auth-rbac-plan.md). Do not set
# them to an empty string in your real .env — set a real value or omit the line.
# NEXTAUTH_SECRET="<run: openssl rand -base64 32>"
# NEXTAUTH_URL="https://your-deployment-url"
# AUTH_MICROSOFT_ENTRA_ID_ID=""
# AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=""
