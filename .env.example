# Postgres connection used by Prisma at runtime.
# Local dev: the pre-created Docker/local role + database (no pooler).
# Production (Vercel + Neon): the Neon POOLED connection string (host contains
#   "-pooler") so serverless functions reuse connections instead of opening a
#   fresh one per request. Append ?sslmode=require if Neon omits it.
DATABASE_URL="postgresql://invoicing:invoicing@localhost:5432/invoicing?schema=public"

# Direct (unpooled) connection used by `prisma migrate` / DDL (needs session
# advisory locks the pooler lacks). Local: same as DATABASE_URL. Production
# (Neon): the UNPOOLED connection string (host has no "-pooler").
DIRECT_URL="postgresql://invoicing:invoicing@localhost:5432/invoicing?schema=public"

# Dev identity fallback. Used ONLY when Entra is not configured (the three
# AUTH_MICROSOFT_ENTRA_ID_* vars below). In that mode every request is treated
# as this single admin, so local dev needs no login. When Entra IS configured,
# this is ignored and real sign-in applies.
DEV_ADMIN_EMAIL="admin@ovationwps.com"

# Admin allowlist. Comma-separated emails that get role ADMIN after Entra
# sign-in; everyone else who signs in is an SDM (scoped to the accounts whose
# sdmEmail matches theirs). Case-insensitive. Blank = no admins (everyone SDM).
ADMIN_EMAILS="kstalwar@ovationwps.com"

# Public app name (optional; has a default).
NEXT_PUBLIC_APP_NAME="Ovation Invoicing"

# Soft-delete affordances (timesheet cell/row/month, dispatch visit).
# "true" enables them. Recommended "true" while testing so delete/restore works.
SOFT_DELETE_ENABLED="false"

# Legacy shared-password gate — SUPERSEDED by Entra sign-in (src/middleware.ts).
# When the three AUTH_MICROSOFT_ENTRA_ID_* vars are set, the middleware uses the
# NextAuth gate and ignores these. Remove them from prod once Entra is verified.
# BASIC_AUTH_USER="testers"
# BASIC_AUTH_PASSWORD="<a long random shared password>"

# --- NextAuth / Microsoft Entra ID ---
# Set all of NEXTAUTH_SECRET + the three AUTH_MICROSOFT_ENTRA_ID_* to turn ON
# real sign-in. If any is missing, the app falls back to the DEV_ADMIN_EMAIL
# identity (local dev). Do NOT set these to "" in a real .env — omit the line or
# set a real value. Azure setup: see docs/ENTRA-SETUP.md.
# NEXTAUTH_SECRET="<run: openssl rand -base64 32>"
# AUTH_MICROSOFT_ENTRA_ID_ID="<Application (client) ID>"
# AUTH_MICROSOFT_ENTRA_ID_SECRET="<client secret VALUE>"
# AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="<Directory (tenant) ID>"
