// Invoicing project - rate-sheet-v2 schema
// See CLAUDE.md for entity-model intent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------------
// Enums
// -------------------------------------------------------------------

enum UserRole {
  ADMIN
  SDM
}

enum OutputTemplate {
  FSO
  PRE_INVOICE
}

// The three top-level rate categories on every account's rate sheet.
enum RateCategory {
  DEDICATED // formerly TechType.FTE
  PROJECT_TM // formerly TechType.PROJECT
  DISPATCH_SCHED // dispatch + scheduled visit (merged)
}

enum InvoiceFormat {
  FSO
  PRE_INVOICE
}

enum MiscFeeKind {
  MISCELLANEOUS_PRICES
  RETAINER_FEES
  MILEAGE
  BGV_COST
  PER_DIEM
  TOOLKIT
  ACCOUNT_SPECIFIC
  OTHER
}

// -------------------------------------------------------------------
// Domain — Org / ClientAccount preserved
// -------------------------------------------------------------------

model Org {
  id              String         @id @default(cuid())
  name            String         @unique
  outputTemplate  OutputTemplate
  defaultCurrency String         @default("USD")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  clientAccounts ClientAccount[]
  technicians    Technician[]

  @@map("orgs")
}

model ClientAccount {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  currency  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org          Org                 @relation(fields: [orgId], references: [id])
  accountRates AccountRate[]
  miscFees     MiscFee[]
  assignments  Assignment[]
  invoiceRuns  InvoiceRun[]
  userAccess   UserAccountAccess[]

  @@unique([orgId, name])
  @@map("client_accounts")
}

// -------------------------------------------------------------------
// Rate-sheet masters (extensible — SLAs + sub-categories may grow)
// -------------------------------------------------------------------

// SLA master — NBD / SBD / 2BD / 3BD / 9X5X4 / 24X7X4 / SCHEDULE / NA
model Sla {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0)

  accountRates AccountRate[]

  @@map("slas")
}

// Rate sub-category master — one row per (rate category, sub-cat code).
// e.g. (DISPATCH_SCHED, FIRST_HOUR), (PROJECT_TM, FULL_DAY), (DEDICATED, ANNUAL_BACKFILL)
model RateSubCategory {
  id                String       @id @default(cuid())
  rateCategory      RateCategory
  code              String
  label             String
  sortOrder         Int          @default(0)
  // True for sub-categories that already represent an OT/weekend variant
  // (e.g. HOURLY_BACKFILL_OT); the UI groups these with their base sub-cat.
  isOvertimeVariant Boolean      @default(false)

  accountRates AccountRate[]

  @@unique([rateCategory, code])
  @@map("rate_sub_categories")
}

// Per-account rate row. `rateAmount` is nullable so admins can leave the
// cell blank and fill in later when commercials are finalised.
model AccountRate {
  id                String    @id @default(cuid())
  clientAccountId   String
  rateSubCategoryId String
  band              Int // 0..4
  slaId             String
  rateAmount        Decimal?  @db.Decimal(12, 4)
  effectiveFrom     DateTime  @db.Date
  effectiveTo       DateTime? @db.Date
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  clientAccount   ClientAccount   @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  rateSubCategory RateSubCategory @relation(fields: [rateSubCategoryId], references: [id])
  sla             Sla             @relation(fields: [slaId], references: [id])

  @@unique([clientAccountId, rateSubCategoryId, band, slaId, effectiveFrom])
  @@index([clientAccountId, rateSubCategoryId])
  @@index([clientAccountId, band])
  @@map("account_rates")
}

// Account-level miscellaneous fees (retainer, mileage, BGV, per diem, …).
model MiscFee {
  id              String      @id @default(cuid())
  clientAccountId String
  kind            MiscFeeKind
  label           String
  amount          Decimal?    @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@index([clientAccountId])
  @@map("misc_fees")
}

// -------------------------------------------------------------------
// Workforce
// -------------------------------------------------------------------

model Technician {
  id              String       @id @default(cuid())
  employerOrgId   String
  firstName       String
  lastName        String
  primaryCategory RateCategory
  band            Int // 0..4, technician's level/seniority
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  employerOrg Org          @relation(fields: [employerOrgId], references: [id])
  assignments Assignment[]

  @@index([employerOrgId, active])
  @@index([primaryCategory, band])
  @@map("technicians")
}

model Assignment {
  id              String       @id @default(cuid())
  technicianId    String
  clientAccountId String
  rateCategory    RateCategory
  startDate       DateTime     @db.Date
  endDate         DateTime?    @db.Date
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  technician       Technician       @relation(fields: [technicianId], references: [id])
  clientAccount    ClientAccount    @relation(fields: [clientAccountId], references: [id])
  timesheetEntries TimesheetEntry[]

  @@index([technicianId, startDate])
  @@index([clientAccountId, startDate])
  @@map("assignments")
}

model TimesheetEntry {
  id           String   @id @default(cuid())
  assignmentId String
  date         DateTime @db.Date
  hours        Decimal  @db.Decimal(6, 2)
  enteredById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  enteredBy  User       @relation(fields: [enteredById], references: [id])

  @@unique([assignmentId, date])
  @@index([date])
  @@map("timesheet_entries")
}

model InvoiceRun {
  id              String        @id @default(cuid())
  clientAccountId String
  periodYear      Int
  periodMonth     Int
  format          InvoiceFormat
  fileUrl         String?
  generatedById   String
  generatedAt     DateTime      @default(now())

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id])
  generatedBy   User          @relation(fields: [generatedById], references: [id])

  @@index([clientAccountId, periodYear, periodMonth])
  @@map("invoice_runs")
}

// -------------------------------------------------------------------
// Identity + scoping
// -------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(SDM)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  userAccountAccess UserAccountAccess[]
  invoiceRuns       InvoiceRun[]
  timesheetEntries  TimesheetEntry[]

  @@map("users")
}

model UserAccountAccess {
  id              String   @id @default(cuid())
  userId          String
  clientAccountId String
  grantedAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, clientAccountId])
  @@map("user_account_access")
}

// -------------------------------------------------------------------
// NextAuth adapter models (Phase 3 wiring)
// -------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}
